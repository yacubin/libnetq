/* Use CryptoHash implementation from the Advapi32 library */
#cmakedefine NQ_USE_ADVAPI32_CRYPTOHASH

/* Use CryptoHash implementation from the OpenSSL library */
#cmakedefine NQ_USE_OPENSSL_CRYPTOHASH

/* Use MD4 implementation from the OpenSSL library */
#cmakedefine NQ_USE_OPENSSL_MD4

/* Use MD5 implementation from the OpenSSL library */
#cmakedefine NQ_USE_OPENSSL_MD5

/* Use SHA1 implementation from the OpenSSL library */
#cmakedefine NQ_USE_OPENSSL_SHA1

/* Use cypto random implementation from the OpenSSL library */
#cmakedefine NQ_USE_OPENSSL_CRYPTORAND

/* Use CRC32 implementation from the ZLib library */
#cmakedefine NQ_USE_ZLIB_CRC32

/* Use JSON implementation from the Jansson library */
#cmakedefine NQ_USE_JANSSON_JSON

/* Use JSON implementation from the cJSON library */
#cmakedefine NQ_USE_CJSON_JSON

/* Use Regex implementation from the PCRE2 library */
#cmakedefine NQ_USE_PCRE2_REGEX

/* Use XMLParser implementation from the Expat library */
#cmakedefine NQ_USE_EXPAT_XMLPARSER

/* Use Atomic implementation from the AtomicOps library */
#cmakedefine NQ_USE_ATOMICOPS_ATOMIC

/* Use native Atomic implementation */
#cmakedefine NQ_USE_NATIVE_ATOMIC

/* Use Base58 implementation from the LibBase58 library */
#cmakedefine NQ_USE_LIBBASE58_BASE58

/* Use Secp256k1 implementation from the Secp256k1 library */
#cmakedefine NQ_USE_SECP256K1_SECP256K1

/* Use stub for CryptoHash */
#cmakedefine NQ_USE_STUB_CRYPTOHASH

/* Use stub for CRC32 */
#cmakedefine NQ_USE_STUB_CRC32

/* Use stub for JSON */
#cmakedefine NQ_USE_STUB_JSON

/* Use stub for Regex */
#cmakedefine NQ_USE_STUB_REGEX

/* Use stub for XMLParser */
#cmakedefine NQ_USE_STUB_XMLPARSER

/* Use stub for Base58 */
#cmakedefine NQ_USE_STUB_BASE58

/* Use stub for Secp256k1 */
#cmakedefine NQ_USE_STUB_SECP256K1

/* Use native cypto random implementation */
#cmakedefine NQ_USE_PLATFORM_CRYPTORAND
