#ifndef NQ_HTTP_STATUS
# error The NQ_HTTP_STATUS macro is not defined
#endif

// <code> <message> <id> <name>
NQ_HTTP_STATUS(100, "Continue",              CONTINUE,                   Continue)
NQ_HTTP_STATUS(101, "Switching Protocols",   SWITCHING_PROTOCOLS,        SwitchingProtocols)
NQ_HTTP_STATUS(102, "Processing",            PROCESSING,                 Processing)
NQ_HTTP_STATUS(103, "Early Hints",           EARLY_HINTS,                EarlyHints)
NQ_HTTP_STATUS(200, "OK",                    OK,                         Ok)
NQ_HTTP_STATUS(201, "Created",               CREATED,                    Created)
NQ_HTTP_STATUS(202, "Accepted",              ACCEPTED,                   Accepted)
NQ_HTTP_STATUS(204, "No Content",            NO_CONTENT,                 NoContent)
NQ_HTTP_STATUS(205, "Reset Content",         RESET_CONTENT,              ResetContent)
NQ_HTTP_STATUS(206, "Partial Content",       PARTIAL_CONTENT,            PartialContent)
NQ_HTTP_STATUS(301, "Moved Permanently",     MOVED_PERMANENTLY,          MovedPermanently)
NQ_HTTP_STATUS(302, "Found",                 MOVED_TEMPORARILY,          MovedTemporarily)
NQ_HTTP_STATUS(304, "Not Modified",          NOT_MODIFIED,               NotModified)
NQ_HTTP_STATUS(307, "Temporary Redirect",    TEMPORARY_REDIRECT,         TemporaryRedirect)
NQ_HTTP_STATUS(400, "Bad Request",           BAD_REQUEST,                BadRequest)
NQ_HTTP_STATUS(401, "Unauthorized",          UNAUTHORIZED,               Unauthorized)
NQ_HTTP_STATUS(404, "Not Found",             NOT_FOUND,                  NotFound)
NQ_HTTP_STATUS(405, "Method Not Allowed",    NOT_ALLOWED,                NotAllowed)
NQ_HTTP_STATUS(412, "Precondition Failed",   PRECONDITION_FAILED,        PreconditionFailed)
NQ_HTTP_STATUS(413, "Content Too Large",     REQUEST_ENTITY_TOO_LARGE,   RequestEntityTooLarge)
NQ_HTTP_STATUS(417, "Expectation Failed",    EXPECTATION_FAILED,         ExpectationFailed)
NQ_HTTP_STATUS(426, "Upgrade Required",      UPGRADE_REQUIRED,           UpgradeRequired)
NQ_HTTP_STATUS(500, "Internal Server Error", INTERNAL_SERVER_ERROR,      InternalServerError)
NQ_HTTP_STATUS(501, "Not Implemented",       NOT_IMPLEMENTED,            NotImplemented)
NQ_HTTP_STATUS(503, "Service Unavailable",   SERVICE_UNAVAILABLE,        ServerUnavailable)
