#ifndef NQ_HTTP_STATUS_DEF
# error The NQ_HTTP_STATUS_DEF macro is not defined
#endif

// <code> <message> <id> <name>
NQ_HTTP_STATUS_DEF(100, "Continue",              CONTINUE,              Continue)
NQ_HTTP_STATUS_DEF(101, "Switching Protocols",   SWITCHING_PROTOCOLS,   SwitchingProtocols)
NQ_HTTP_STATUS_DEF(102, "Processing",            PROCESSING,            Processing)
NQ_HTTP_STATUS_DEF(103, "Early Hints",           EARLY_HINTS,           EarlyHints)
NQ_HTTP_STATUS_DEF(200, "OK",                    OK,                    Ok)
NQ_HTTP_STATUS_DEF(201, "Created",               CREATED,               Created)
NQ_HTTP_STATUS_DEF(301, "Moved Permanently",     MOVED_PERMANENTLY,     MovedPermanently)
NQ_HTTP_STATUS_DEF(307, "Temporary Redirect",    TEMPORARY_REDIRECT,    TemporaryRedirect)
NQ_HTTP_STATUS_DEF(404, "Not Found",             NOT_FOUND,             NotFound)
NQ_HTTP_STATUS_DEF(412, "Precondition Failed",   PRECONDITION_FAILED,   PreconditionFailed)
NQ_HTTP_STATUS_DEF(426, "Upgrade Required",      UPGRADE_REQUIRED,      UpgradeRequired)
NQ_HTTP_STATUS_DEF(500, "Internal Server Error", INTERNAL_SERVER_ERROR, InternalServerError)
