#ifndef NQ_MIMETYPE
# error The NQ_MIMETYPE macro is not defined
#endif

// <typ> <extname> [...<extname>]
NQ_MIMETYPE("application/javascript", ".js")
NQ_MIMETYPE("application/json",       ".json")
NQ_MIMETYPE("application/wasm",       ".wasm")
NQ_MIMETYPE("application/x-abiword",  ".abw")
NQ_MIMETYPE("application/x-gzip",     ".gz")
NQ_MIMETYPE("audio/3gpp",             ".3gp", ".3gpp")
NQ_MIMETYPE("audio/3gp2",             ".3g2", ".3gp2", ".3gpp2")
NQ_MIMETYPE("audio/mp4",              ".m4a", ".m4b", ".m4p", ".m4r")
NQ_MIMETYPE("audio/aac",              ".aac")
NQ_MIMETYPE("image/png",              ".png")
NQ_MIMETYPE("image/svg+xml",          ".svg", ".svgz")
NQ_MIMETYPE("image/x-icon",           ".ico")
NQ_MIMETYPE("text/css",               ".css")
NQ_MIMETYPE("text/html",              ".html", ".htm", ".shtml")
NQ_MIMETYPE("text/plain",             ".txt")
NQ_MIMETYPE("video/3gpp",             ".3gp", ".3gpp")
NQ_MIMETYPE("video/3gp2",             ".3g2", ".3gp2", ".3gpp2")
NQ_MIMETYPE("video/mp4",              ".mp4", ".m4v")
